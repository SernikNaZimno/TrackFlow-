generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email            String   @unique
  passwordHash     String   @map("password_hash")
  role             String   // 'marketer' | 'client'
  agencyClientName String?  @map("agency_client_name")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relacje
  createdLinks Link[]   @relation("CreatedBy")
  clientLinks  Link[]   @relation("ClientForLink")
  reports      Report[]

  @@map("users")
}

model Link {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shortCode    String    @unique @map("short_code") @db.VarChar(10)
  originalUrl  String    @map("original_url")
  campaignName String?   @map("campaign_name") @db.VarChar(255)
  clientId     String?   @map("client_id") @db.Uuid
  createdBy    String    @map("created_by") @db.Uuid
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz
  isActive     Boolean   @default(true) @map("is_active")
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relacje
  creator User    @relation("CreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  client  User?   @relation("ClientForLink", fields: [clientId], references: [id])
  clicks  Click[]

  @@map("links")
}

model Click {
  id         BigInt   @id @default(autoincrement())
  linkId     String   @map("link_id") @db.Uuid
  clickedAt  DateTime @map("clicked_at") @db.Timestamptz
  country    String?  @db.VarChar(2)
  city       String?  @db.VarChar(100)
  deviceType String?  @map("device_type") @db.VarChar(10) // 'mobile' | 'desktop' | 'tablet'
  browser    String?  @db.VarChar(50)
  os         String?  @db.VarChar(50)
  referrer   String?
  ipHash     String?  @map("ip_hash") @db.VarChar(64)
  eventId    String   @unique @map("event_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relacje
  link Link @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId, clickedAt])
  @@map("clicks")
}

model Report {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  status       String    // 'pending' | 'processing' | 'done' | 'failed'
  requestedBy  String    @map("requested_by") @db.Uuid
  dateFrom     DateTime  @map("date_from") @db.Timestamptz
  dateTo       DateTime  @map("date_to") @db.Timestamptz
  linkIds      String[]  @map("link_ids") @db.Uuid
  filePath     String?   @map("file_path")
  errorMessage String?   @map("error_message")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  completedAt  DateTime? @map("completed_at") @db.Timestamptz

  // Relacje
  requester User @relation(fields: [requestedBy], references: [id], onDelete: Restrict)

  @@map("reports")
}
